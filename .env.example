// CONFIG
PORT=3000
CORS=*

// MONGO
// Leave DB_USER and DB_PASSWORD empty for local dev (in-memory store)
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_NAME=properties-dev
DB_PORT=27017

// USERS
DEFAULT_ADMIN_PASSWORD=admin123
DEFAULT_USER_PASSWORD=user123

// AUTH
AUTH_JWT_SECRET=dev-jwt-secret-do-not-use-in-production

// API KEYS
PUBLIC_API_KEY_TOKEN=public-dev-token
ADMIN_API_KEY_TOKEN=admin-dev-token

// SPOTIFY API
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

// GOOGLE API
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
